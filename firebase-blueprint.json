{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "dealer"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Proposal": {
      "title": "Report Proposal",
      "description": "Stores the generated report data.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The proposal's unique ID." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "systemType": { "type": "string", "enum": ["CHILLER", "COOLING_TOWER"], "description": "The type of system." },
        "data": { "type": "object", "description": "The raw report data." },
        "authorUid": { "type": "string", "description": "The UID of the user who created the report." },
        "authorEmail": { "type": "string", "format": "email", "description": "The email of the user who created the report." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created." }
      },
      "required": ["id", "customerName", "systemType", "data", "authorUid", "authorEmail", "createdAt"]
    },
    "ExportLog": {
      "title": "Export Log",
      "description": "Tracks when a user exports a report.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The log's unique ID." },
        "proposalId": { "type": "string", "description": "The ID of the exported proposal." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "authorUid": { "type": "string", "description": "The UID of the user who exported the report." },
        "authorEmail": { "type": "string", "format": "email", "description": "The email of the user who exported the report." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the export occurred." },
        "chemicalUsage": { "type": "object", "description": "Summary of chemical usage in the report." }
      },
      "required": ["id", "proposalId", "customerName", "authorUid", "authorEmail", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/proposals/{proposalId}": {
      "schema": "Proposal",
      "description": "Collection of generated reports."
    },
    "/exportLogs/{logId}": {
      "schema": "ExportLog",
      "description": "Collection of export event logs."
    }
  }
}
